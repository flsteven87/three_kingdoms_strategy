# =============================================================================
# Three Kingdoms Strategy Manager - Frontend Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (必填 🔴)
# -----------------------------------------------------------------------------
# 從 https://app.supabase.com/project/<your-project>/settings/api 取得
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------
# Local: http://localhost:8087
# Production: https://api.tktmanager.com
VITE_API_BASE_URL=http://localhost:8087

# -----------------------------------------------------------------------------
# LINE LIFF Configuration (LIFF 功能必填)
# -----------------------------------------------------------------------------
# 從 LINE Developers Console > LIFF App 取得
VITE_LIFF_ID=your_liff_id_here
# Bot Basic ID (從 Messaging API tab 取得，用於加好友連結)
VITE_LINE_BOT_ID=@your_bot_basic_id_here

# -----------------------------------------------------------------------------
# Recur Payment Configuration (金流功能必填)
# -----------------------------------------------------------------------------
# 從 Recur Dashboard > Settings > API Keys 取得
VITE_RECUR_PUBLISHABLE_KEY=pk_test_your_key_here
# 從 Recur Dashboard > Products 取得你的產品 ID
VITE_RECUR_PRODUCT_ID=prod_your_product_id_here
