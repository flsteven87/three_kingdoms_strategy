# =============================================================================
# Three Kingdoms Strategy Manager - Backend Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (必填 🔴)
# -----------------------------------------------------------------------------
# 從 https://app.supabase.com/project/<your-project>/settings/api 取得
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:8087
FRONTEND_URL=http://localhost:5187
CORS_ORIGINS=http://localhost:5187

# -----------------------------------------------------------------------------
# Security (必填 🔴)
# -----------------------------------------------------------------------------
# 使用 openssl rand -hex 32 生成
SECRET_KEY=your_secret_key_here

# -----------------------------------------------------------------------------
# Environment Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# LINE Bot Configuration (LINE 三國小幫手)
# -----------------------------------------------------------------------------
# 從 LINE Developers Console 取得：https://developers.line.biz/console/
# 1. 建立 Messaging API Channel
# 2. 建立 LIFF App (在同一 Channel 下)
LINE_CHANNEL_ID=your_line_channel_id_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_ACCESS_TOKEN=your_line_channel_access_token_here
LIFF_ID=your_liff_id_here
# Bot Basic ID (從 Messaging API tab 取得，用於加好友連結)
LINE_BOT_ID=@your_bot_basic_id_here
# Bot User ID (用於 @mention 偵測，執行: curl -H "Authorization: Bearer $LINE_ACCESS_TOKEN" https://api.line.me/v2/bot/info)
LINE_BOT_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Recur Payment Configuration (金流功能)
# -----------------------------------------------------------------------------
# 從 Recur Dashboard > Settings > API Keys 取得 (production 請用 sk_live_*)
RECUR_SECRET_KEY=sk_live_your_secret_key_here
# Webhook Signing Secret (從 Recur Dashboard > Webhooks > 你的 webhook > Signing Secret)
RECUR_WEBHOOK_SECRET=your_webhook_signing_secret_here
# Product id from Recur dashboard — server rejects webhooks with any other productId
RECUR_PRODUCT_ID=prod_your_product_id_here
# Expected charge (integer TWD) — server rejects webhooks with any other amount
RECUR_EXPECTED_AMOUNT_TWD=999
# Expected currency code — server rejects webhooks with any other currency
RECUR_EXPECTED_CURRENCY=TWD

# -----------------------------------------------------------------------------
# Critical Alert Webhook (optional)
# -----------------------------------------------------------------------------
# Discord/Slack-compatible webhook for signature failures and permanent
# payment-webhook errors. Leave empty to log-only.
ALERT_WEBHOOK_URL=
